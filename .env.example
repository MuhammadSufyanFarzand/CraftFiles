# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (e.g. from Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_your_fake_key_here
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Admin Access ──────────────────────────────────────────────────────────────
# Comma-separated Clerk user IDs who can access the /admin panel
# Find your user ID in Clerk dashboard → Users, or call GET /api/users/me after sign-in
ADMIN_USER_IDS=user_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
